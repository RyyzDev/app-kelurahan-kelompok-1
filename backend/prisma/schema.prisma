// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  warga
  admin
  petugas
}

model User {
  id            String    @id @default(uuid())
  nik           String    @unique // Dienkripsi di DB sesuai GEMINI.md
  email         String?   @unique
  nama_lengkap  String
  tanggal_lahir DateTime?
  phone         String?
  alamat        String?   // Dienkripsi di DB sesuai GEMINI.md
  password      String    // bcrypt hash
  role          Role      @default(warga)
  is_active     Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  permohonan    PermohonanSurat[]
  toko          Toko?
  orders          Order[]
  event_registrations EventRegistration[]
  pendaftaran_vaksinasi PendaftaranVaksinasi[]
  aspirasi      Aspirasi[]

  @@map("users")
}

enum StatusPembayaran {
  pending
  berhasil
  gagal
  kadaluarsa
  dibatalkan
}

model Order {
  id                String           @id @default(uuid())
  user_id           String
  total_harga       Decimal          @db.Decimal(12, 2)
  status_pembayaran StatusPembayaran @default(pending)
  snap_token        String?
  snap_redirect_url String?
  
  user              User             @relation(fields: [user_id], references: [id])
  items             OrderItem[]

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  order_id    String
  produk_id   String
  nama_produk String
  harga       Decimal  @db.Decimal(12, 2)
  kuantitas   Int

  order       Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Toko {
  id            String    @id @default(uuid())
  user_id       String    @unique
  nama_toko     String
  deskripsi     String?
  alamat_toko   String?
  phone_toko    String?
  is_active     Boolean   @default(true)
  
  user          User      @relation(fields: [user_id], references: [id])
  produk        Produk[]

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("toko")
}

enum StatusProduk {
  pending
  disetujui
  ditolak
}

model Produk {
  id              String       @id @default(uuid())
  toko_id         String
  nama_produk     String
  deskripsi       String?
  harga           Decimal      @db.Decimal(12, 2)
  kategori        String?
  stok            Int          @default(0)
  foto_url        String?
  status          StatusProduk @default(pending)
  catatan_admin   String?
  
  toko            Toko         @relation(fields: [toko_id], references: [id])

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("produk")
}

model JenisSurat {
  id                String   @id @default(uuid())
  nama_layanan      String   @unique
  deskripsi         String?
  persyaratan       String[] // Array of strings for required documents
  estimasi_pengerjaan Int?      // In working days
  is_active         Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  permohonan        PermohonanSurat[]
  @@map("jenis_surat")
}

enum FormatSurat {
  digital
  cap_basah
}

enum StatusPermohonan {
  verifikasi
  penandatanganan_rt
  penandatanganan_rw
  penandatanganan
  siap_diambil
  siap_didownload
  selesai
  ditolak
}

model PermohonanSurat {
  id                String           @id @default(uuid())
  user_id           String
  jenis_surat_id    String
  format_surat      FormatSurat      @default(digital)
  alasan_permohonan String
  status            StatusPermohonan @default(verifikasi)
  catatan_admin     String?
  file_url          String?          // URL untuk download jika format digital
  nomor_surat       String?          // Nomor surat resmi setelah disetujui
  
  user              User             @relation(fields: [user_id], references: [id])
  jenis_surat       JenisSurat       @relation(fields: [jenis_surat_id], references: [id])

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("permohonan_surat")
}

enum StatusEvent {
  aktif
  berakhir
}

model Event {
  id          String      @id @default(uuid())
  nama_event  String
  deskripsi   String?
  tanggal     DateTime
  lokasi      String?
  foto_url    String?
  status      StatusEvent @default(aktif)
  
  registrations EventRegistration[]
  
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("events")
}

model EventRegistration {
  id              String      @id @default(uuid())
  user_id         String
  event_id        String
  registeredAt    DateTime    @default(now()) @map("registered_at")

  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event           Event       @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@unique([user_id, event_id])
  @@map("event_registrations")
}

enum StatusVaksinasi {
  TERSEDIA
  PENUH
  SELESAI
}

model JadwalVaksinasi {
  id            String      @id @default(uuid())
  nama_vaksin   String
  deskripsi     String?
  tanggal       DateTime
  jam_mulai     String
  jam_selesai   String
  lokasi        String
  kuota         Int
  sisa_kuota    Int
  status        StatusVaksinasi @default(TERSEDIA)
  
  pendaftar     PendaftaranVaksinasi[]

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("jadwal_vaksinasi")
}

model PendaftaranVaksinasi {
  id              String      @id @default(uuid())
  user_id         String
  jadwal_id       String
  nomor_antrian   Int
  status          String      @default("terdaftar") // terdaftar, hadir, tidak_hadir

  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  jadwal          JadwalVaksinasi @relation(fields: [jadwal_id], references: [id], onDelete: Cascade)

  registeredAt    DateTime    @default(now()) @map("registered_at")

  @@unique([user_id, jadwal_id])
  @@map("pendaftaran_vaksinasi")
}

model Pengumuman {
  id        String   @id @default(uuid())
  judul     String
  konten    String
  tanggal   DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pengumuman")
}

model Aspirasi {
  id        String   @id @default(uuid())
  user_id   String
  pesan     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("aspirasi")
}
